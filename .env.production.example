# Frontend production environment variables
# In Vercel: Project → Settings → Environment Variables
# Set these for the "Production" environment.
# Do NOT commit real values to git.

# Your Render backend URL (no trailing slash)
NEXT_PUBLIC_API_URL=https://dineflow-api.onrender.com

# WebSocket URL — must use wss:// in production (Render supports it natively)
NEXT_PUBLIC_WS_URL=wss://dineflow-api.onrender.com
